":{},"additionalProperties":{"type":"object","additionalProperties":{"type":"string"}},"description":"Map of ACP agent IDs to default session config preferences. Each key is an agent ID and the value is an object mapping config option IDs to their preferred default values, applied automatically when a new session is created."}}},"menus":{"commandPalette":[{"command":"windsurf.openBillingPage","when":"!windsurf:isDevin"},{"command":"windsurf.openAutoRefillPage","when":"!windsurf:isDevin"},{"command":"windsurf.importRulesFromCursor"},{"command":"windsurf.createWorkflow"},{"command":"windsurf.createGlobalWorkflow"},{"command":"windsurf.createRule"},{"command":"windsurf.openBrowser","when":"windsurf.browserFeatureEnabled"},{"command":"windsurf.importCursorSettings","when":"windsurf:enableCursorImportCursor","group":"2_import"},{"command":"windsurf.importCursorExtensions","when":"windsurf:enableCursorImportCursor","group":"2_import"},{"command":"windsurf.importVSCodeSettings","when":"windsurf:enableVSCodeImport","group":"2_import"},{"command":"windsurf.importVSCodeExtensions","when":"windsurf:enableVSCodeImport","group":"2_import"},{"command":"windsurf.importWindsurfSettings","when":"windsurf:isNextOrInsiders","group":"2_import"},{"command":"windsurf.importWindsurfExtensions","when":"windsurf:isNextOrInsiders","group":"2_import"},{"command":"windsurf.copyApiKey","when":"windsurf:isInternalUser"},{"command":"windsurf.reloadAcpConnections","when":"windsurf:acpEnabled"},{"command":"windsurf.openAcpLocalRegistry","when":"windsurf:acpEnabled"},{"command":"windsurf.lifeguard.checkCurrentChanges","when":"lifeguardEnabled"},{"command":"windsurf.lifeguard.evaluateDataset","when":"lifeguardEnabled && windsurf:isInternalUser"}]},"keybindings":[{"command":"windsurf.prioritized.terminalCommand.open","key":"ctrl+i","mac":"cmd+i","when":"terminalFocus && !cascadeUiTerminalFocus && !cascadeManagedTerminalFocus"},{"command":"windsurf.terminalCommand.run","key":"ctrl+enter","mac":"cmd+ent